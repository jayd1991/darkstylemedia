---
interface Props {
  project: {
    id: number;
    title: string;
    category: string;
    description: string;
    image: string;
    images?: string[];
    gradient: string;
    videoUrl?: string;
    loop?: boolean;
    featured?: boolean;
  };
}

const { project } = Astro.props;
const isVideo = project.category === 'videography';
const loopSrc = project.loop && project.videoUrl ? project.videoUrl : null;

// Build the effective image list for cycling
const cycleImages: string[] =
  project.images && project.images.length > 0
    ? project.images
    : project.image
      ? [project.image]
      : [];
const firstImage = cycleImages[0] ?? null;
const hasCycle   = cycleImages.length > 1;
---

<article class="card" data-category={project.category}>
  <div class="card-media" data-photos={(!isVideo && cycleImages.length > 0) ? JSON.stringify(cycleImages) : undefined}>
    <!-- Gradient shown while image loads or if no image is set -->
    <div class="card-bg" style={`background: ${project.gradient}`}></div>

    {loopSrc ? (
      <video
        class="card-video"
        autoplay
        muted
        loop
        playsinline
        poster={project.image || undefined}
        controlsList="nodownload"
        disablePictureInPicture
        oncontextmenu="return false"
      >
        <source src={loopSrc} />
      </video>
    ) : firstImage ? (
      <img
        src={firstImage}
        alt={project.title}
        class="card-img"
        loading={hasCycle ? 'eager' : 'lazy'}
        data-cycle={hasCycle ? JSON.stringify(cycleImages) : undefined}
        onload={!hasCycle ? "this.style.opacity='1'" : undefined}
        onerror={!hasCycle ? "this.style.opacity='0'" : undefined}
      />
    ) : null}

    <div class="card-overlay">
      <p class="card-desc">{project.description}</p>
      {isVideo && project.videoUrl && (
        <button class="card-play-btn" data-video={project.videoUrl} data-loop={project.loop ? 'true' : undefined} aria-label={`Watch ${project.title}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
          Watch
        </button>
      )}
      {!isVideo && cycleImages.length > 0 && (
        <button class="card-play-btn" data-photos={JSON.stringify(cycleImages)} aria-label={`View ${project.title}`}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zm-8.5-5.5l-2.5 3.01L7 14l-3 4h16l-5-6.5z"/>
          </svg>
          View
        </button>
      )}
    </div>

    {isVideo && (
      <span class="card-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17 10.5V7a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h12a1 1 0 001-1v-3.5l4 4v-11l-4 4z"/>
        </svg>
        Video
      </span>
    )}
  </div>

  <div class="card-info">
    <span class="card-cat">{project.category}</span>
    <h3 class="card-title">{project.title}</h3>
  </div>
</article>

<script>
  document.querySelectorAll<HTMLImageElement>('img[data-cycle]').forEach(seed => {
    const srcs: string[] = JSON.parse(seed.getAttribute('data-cycle')!);
    srcs.forEach(src => { new Image().src = src; });

    let current = seed;
    let lastSrc = seed.src;
    let queue: string[] = [];

    function refillQueue(): void {
      const deck = [...srcs];
      for (let i = deck.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [deck[i], deck[j]] = [deck[j], deck[i]];
      }
      if (deck.length > 1 && deck[0] === lastSrc) deck.push(deck.shift()!);
      queue = deck;
    }

    function nextSrc(): string {
      if (queue.length === 0) refillQueue();
      return queue.shift()!;
    }

    function crossfade(): void {
      const next = nextSrc();
      lastSrc = next;

      const incoming = document.createElement('img');
      incoming.className = 'card-img';
      incoming.alt = '';
      incoming.setAttribute('aria-hidden', 'true');
      // Astro scoped CSS never reaches dynamically created elements, so all
      // layout and transition properties must be applied as inline styles.
      Object.assign(incoming.style, {
        position: 'absolute',
        inset: '0',
        width: '100%',
        height: '100%',
        objectFit: 'cover',
        opacity: '0',
        transition: 'opacity 1.4s ease-out',
      });
      current.after(incoming); // above current in DOM order, below .card-overlay

      const doFade = () => {
        // offsetWidth read forces a style/layout flush so the browser commits
        // opacity:0 before we change it — this guarantees the CSS transition fires
        void incoming.offsetWidth;
        incoming.style.opacity = '1';
        setTimeout(() => {
          current.remove(); // fully hidden behind the now-opaque incoming image
          current = incoming;
          setTimeout(crossfade, 5000);
        }, 1400);
      };

      incoming.src = next;
      if (incoming.complete && incoming.naturalWidth > 0) {
        doFade();
      } else {
        incoming.onload  = doFade;
        incoming.onerror = () => { incoming.remove(); setTimeout(crossfade, 5000); };
      }
    }

    function init(): void {
      void seed.offsetWidth; // same flush for the initial fade-in
      seed.style.opacity = '1';
      setTimeout(crossfade, 5000);
    }

    if (seed.complete && seed.naturalWidth > 0) init();
    else {
      seed.onload  = init;
      seed.onerror = () => { seed.style.opacity = '0'; };
    }
  });
</script>

<style>
  .card { cursor: default; }

  .card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--surface);
  }

  .card-media[data-photos] { cursor: pointer; }

  .card-bg {
    position: absolute;
    inset: 0;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: transform 0.6s ease, opacity 1.4s ease-out;
  }

  .card:hover .card-img { transform: scale(1.06); }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    background: linear-gradient(to top, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.2) 55%, transparent 100%);
    opacity: 0;
    transition: opacity 0.35s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
    gap: 0.85rem;
  }

  .card:hover .card-overlay { opacity: 1; }

  .card-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.84);
    line-height: 1.55;
    transform: translateY(6px);
    transition: transform 0.35s ease;
  }

  .card:hover .card-desc { transform: translateY(0); }

  .card-play-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 0.45rem 1rem;
    width: fit-content;
    transition: background 0.2s;
  }

  .card-play-btn:hover { background: var(--accent-hover); }

  .card-badge {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.88);
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    padding: 0.28rem 0.6rem;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .card-media::after {
    content: '© DARKSTYLEMEDIA';
    position: absolute;
    bottom: 0.7rem;
    right: 0.85rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(80, 80, 80, 0.85);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.9);
    pointer-events: none;
    z-index: 5;
  }

  .card-info { padding: 0.9rem 0 0; }

  .card-cat {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .card-title {
    font-family: 'Bebas Neue', Arial, sans-serif;
    font-size: 1.45rem;
    letter-spacing: 0.05em;
    color: var(--text);
    margin-top: 0.2rem;
  }
</style>
