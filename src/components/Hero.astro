---
import site from '../data/site.json';
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-line left"></div>
    <div class="hero-line right"></div>
  </div>

  <div class="container hero-content">
    <p class="hero-eyebrow">Photography &middot; Videography</p>
    <h1 class="hero-heading">
      <span class="line-1">DARK<span class="accent">STYLE</span></span>
      <span class="line-2">MEDIA</span>
    </h1>
    <p class="hero-tagline">{site.tagline}</p>
    <div class="hero-actions">
      <a href="/work" class="btn btn-primary">View Work</a>
      <a href="/contact" class="btn btn-ghost">Get In Touch</a>
    </div>
  </div>

  <div class="scroll-hint">
    <span class="scroll-text">Scroll</span>
    <div class="scroll-bar"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background layers */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 80% at 40% 50%, black 20%, transparent 75%);
  }

  .hero-glow {
    position: absolute;
    top: 35%;
    left: 35%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(192,57,43,0.09) 0%, transparent 65%);
  }

  .hero-line {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, transparent 0%, var(--border) 25%, var(--border) 75%, transparent 100%);
    opacity: 0.35;
  }
  .hero-line.left  { left:  clamp(1rem, 4vw, 3rem); }
  .hero-line.right { right: clamp(1rem, 4vw, 3rem); }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: var(--nav-height);
    padding-bottom: 6rem;
  }

  .hero-eyebrow {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.75rem;
    animation: fadeInUp 0.6s ease 0.1s both;
  }

  .hero-heading {
    display: flex;
    flex-direction: column;
    font-size: clamp(4.5rem, 13vw, 11rem);
    line-height: 0.88;
    margin-bottom: 2rem;
  }

  .line-1 {
    animation: fadeInUp 0.8s ease 0.2s both;
  }

  .line-2 {
    font-size: clamp(5.5rem, 17vw, 14rem);
    color: transparent;
    -webkit-text-stroke: 1px rgba(236,232,225,0.12);
    animation: fadeInUp 0.8s ease 0.3s both;
  }

  .accent { color: var(--accent); }

  .hero-tagline {
    font-size: 1rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 360px;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.5s both;
  }

  /* Scroll indicator */
  .scroll-hint {
    position: absolute;
    bottom: 2.25rem;
    right: clamp(1rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    animation: fadeIn 1s ease 1s both;
  }

  .scroll-text {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-dim);
    writing-mode: vertical-rl;
  }

  .scroll-bar {
    width: 1px;
    height: 52px;
    background: var(--border);
    position: relative;
    overflow: hidden;
  }

  .scroll-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    animation: scrollAnim 1.8s ease-in-out infinite;
  }

  @keyframes scrollAnim {
    0%   { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
</style>
