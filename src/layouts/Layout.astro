---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Darkstylemedia',
  description = 'Professional photography and videography. Capturing moments, crafting stories.',
} = Astro.props;

const pageTitle = title === 'Darkstylemedia' ? title : `${title} | Darkstylemedia`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
  <script>
    // Block right-click on images and videos
    document.addEventListener('contextmenu', (e) => {
      const t = e.target as Element;
      if (t instanceof HTMLImageElement || t instanceof HTMLVideoElement || t.closest('#video-modal')) {
        e.preventDefault();
      }
    });
    // Block keyboard shortcuts for saving/viewing source
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && ['s', 'u'].includes(e.key.toLowerCase())) {
        e.preventDefault();
      }
    });
  </script>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Video lightbox -->
    <div id="video-modal" aria-modal="true" role="dialog" aria-label="Video player">
      <div class="vm-backdrop"></div>
      <div class="vm-box">
        <button class="vm-close" aria-label="Close">&times;</button>
        <div class="vm-player">
          <video class="vm-video" controls playsinline controlsList="nodownload" disablePictureInPicture></video>
          <span class="vm-watermark">© DARKSTYLEMEDIA</span>
        </div>
      </div>
    </div>

    <style>
      #video-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9000;
        align-items: center;
        justify-content: center;
      }
      #video-modal.open { display: flex; }

      .vm-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.93);
        cursor: pointer;
      }

      .vm-box {
        position: relative;
        z-index: 1;
        max-width: 92vw;
        max-height: 88vh;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.6rem;
      }

      .vm-close {
        background: none;
        border: 1px solid rgba(255,255,255,0.18);
        color: rgba(255,255,255,0.7);
        font-size: 1.4rem;
        line-height: 1;
        width: 2.2rem;
        height: 2.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.2s, color 0.2s;
        flex-shrink: 0;
      }
      .vm-close:hover { border-color: #fff; color: #fff; }

      .vm-player {
        position: relative;
        line-height: 0;
      }

      .vm-video {
        display: block;
        max-width: 92vw;
        max-height: calc(88vh - 3rem);
        width: auto;
        height: auto;
        background: #000;
        outline: none;
      }

      .vm-watermark {
        position: absolute;
        bottom: 3rem; /* above the video controls bar */
        right: 0.9rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.6rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.45);
        text-shadow: 0 1px 4px rgba(0, 0, 0, 0.9);
        pointer-events: none;
        user-select: none;
      }
    </style>

    <script>
      const modal   = document.getElementById('video-modal')!;
      const video   = modal.querySelector('.vm-video') as HTMLVideoElement;
      const backdrop = modal.querySelector('.vm-backdrop')!;
      const closeBtn = modal.querySelector('.vm-close')!;

      function openModal(url: string) {
        video.src = url;
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
        video.play().catch(() => {});
      }

      function closeModal() {
        modal.classList.remove('open');
        video.pause();
        video.src = '';
        document.body.style.overflow = '';
      }

      document.addEventListener('click', (e) => {
        const btn = (e.target as Element).closest('[data-video]') as HTMLElement | null;
        if (btn?.dataset.video) {
          e.preventDefault();
          video.loop = btn.dataset.loop === 'true';
          openModal(btn.dataset.video);
        }
      });

      backdrop.addEventListener('click', closeModal);
      closeBtn.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });
    </script>
  </body>
</html>
